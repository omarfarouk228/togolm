# PostgreSQL + pgvector
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=togolm
POSTGRES_USER=togolm
POSTGRES_PASSWORD=change_me

# Gemini API (embeddings + generation V1)
GEMINI_API_KEY=your_gemini_api_key_here

# API config
API_SECRET_KEY=change_me_in_production
API_ENV=development

# Celery (async tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Scraping
SCRAPY_CONCURRENT_REQUESTS=4
SCRAPY_DOWNLOAD_DELAY=1.5
