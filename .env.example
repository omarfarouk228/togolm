# PostgreSQL + pgvector
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=togolm
POSTGRES_USER=togolm
POSTGRES_PASSWORD=change_me

# Gemini API (embeddings + generation V1)
GEMINI_API_KEY=your_gemini_api_key_here
# Chat model used for generation, routing, image understanding, etc. (optional,
# defaults to gemini-2.5-flash — see rag/generation/llm.py)
# GEMINI_MODEL=gemini-2.5-flash
# Automatic fallback model: retried once if GEMINI_MODEL fails (quota
# exhausted, model unavailable, etc.). Optional, defaults to gemini-3-flash-preview.
# GEMINI_FALLBACK_MODEL=gemini-3-flash-preview

# API config
API_SECRET_KEY=change_me_in_production
API_ENV=development
# Comma-separated list of valid API keys (empty = dev mode, all keys accepted)
API_KEYS=key1,key2,key3

# Celery (async tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Scraping
SCRAPY_CONCURRENT_REQUESTS=4
SCRAPY_DOWNLOAD_DELAY=1.5
