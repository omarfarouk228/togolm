# ---------------------------------------------------------------------------
# TogoLM Showcase — environment variables
# Copy this file to .env.local and fill in the values.
# ---------------------------------------------------------------------------

# URL of the TogoLM API (no trailing slash)
# Local dev : http://localhost:8000
# Production: your public API domain (e.g. via ngrok or a VPS)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Canonical URL of this showcase (used for SEO metadata and OG image links)
NEXT_PUBLIC_SITE_URL=https://togolm.ai

# Google Analytics 4 Measurement ID (optional)
# Leave empty to disable analytics (e.g. local dev, forks)
NEXT_PUBLIC_GA_ID=
